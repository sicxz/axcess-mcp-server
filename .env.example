# ─── Axcess MCP Server — Environment Variables ──────────────────────────────

# Required: Your USDC recipient address on Base mainnet
# This wallet receives all $0.05 payments
PAYMENT_ADDRESS=0x...

# Required for mainnet: Base mainnet chain ID
# Use eip155:8453  for Base mainnet  (requires CDP_API_KEY_ID + CDP_API_KEY_SECRET)
# Use eip155:84532 for Base Sepolia  (testnet, no CDP keys needed)
X402_NETWORK=eip155:8453

# Required for mainnet: Coinbase Developer Platform API credentials
# Create a free account and API key at https://cdp.coinbase.com
# These are read automatically by the @coinbase/x402 package
CDP_API_KEY_ID=your-cdp-api-key-id
CDP_API_KEY_SECRET=your-cdp-api-key-secret

# Optional: Override the x402 facilitator URL
# Mainnet: handled automatically by @coinbase/x402 when CDP keys are set
# Testnet: defaults to https://x402.org/facilitator
# X402_FACILITATOR_URL=

# Optional: Server port (Railway injects PORT automatically)
PORT=3000

# Optional: Transport mode
# http  — production (default)
# stdio — for local Claude Code / claude_desktop_config.json usage
TRANSPORT=http
